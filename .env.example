# Phantom Grid OS — Environment Variables
# Copy to .env and fill in values. NEVER commit .env.

# ── CDN / SFTP ────────────────────────────────────────────────────────────────
CDN_HOST=cdn.phantom-grid.de
CDN_PORT=22
CDN_USER=
CDN_KEY_PATH=~/.ssh/id_rsa
CDN_BASE_PATH=/releases

# ── CDN Public URL ────────────────────────────────────────────────────────────
CDN_PUBLIC_URL=https://cdn.phantom-grid.de
