#!/bin/bash
# Phantom Grid CLI — bootstrapper
# Activates venv and dispatches to phantom-grid.py

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

if [ ! -d "venv" ]; then
  echo "✗ venv not found. Run: bash tools/setup.sh"
  exit 1
fi

source venv/bin/activate
python phantom-grid.py "$@"
deactivate
